<Project>

  <!-- Build settings -->
  <PropertyGroup>
    <SatelliteResourceLanguages>en-US</SatelliteResourceLanguages>
    <NeutralLanguage>en-US</NeutralLanguage>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>preview</LangVersion>
    <Nullable>enable</Nullable>
    <InvariantGlobalization>true</InvariantGlobalization>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <IsWindows>$([System.OperatingSystem]::IsWindows())</IsWindows>
    <AssemblyOriginatorKeyFile>$(MSBuildThisFileDirectory)Bshox.snk</AssemblyOriginatorKeyFile>
    <SnkPublicKey></SnkPublicKey>
    <SignAssembly>true</SignAssembly>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <EnableTUnitPolyfills>false</EnableTUnitPolyfills>
  </PropertyGroup>

  <!-- Runtime Async -->
  <PropertyGroup Condition="'$(TargetFramework)' == 'net11.0'">
    <Features>$(Features);runtime-async=on</Features>
  </PropertyGroup>

  <!-- Code Analysis -->
  <PropertyGroup>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <!-- TODO: fix -->
    <NoWarn>CS1591</NoWarn>
    <WarningsNotAsErrors>CS1591</WarningsNotAsErrors>
    <CodeAnalysisTreatWarningsAsErrors>false</CodeAnalysisTreatWarningsAsErrors>
    <RunAnalyzersDuringLiveAnalysis>True</RunAnalyzersDuringLiveAnalysis>
    <RunAnalyzersDuringBuild>True</RunAnalyzersDuringBuild>
    <MSBuildTreatWarningsAsErrors>True</MSBuildTreatWarningsAsErrors>
    <AnalysisLevel>11.0</AnalysisLevel>
    <AnalysisMode>All</AnalysisMode>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <!-- <AnalysisModeStyle>Recommended</AnalysisModeStyle> -->
  </PropertyGroup>

  <!-- Package properties -->
  <PropertyGroup>
    <Configuration Condition="'$(Configuration)' == ''">Debug</Configuration>
    <Version Condition="'$(Version)' == ''">0.0.0.0-Dev.$(Configuration)</Version>
    <Product>Bshox</Product>
    <Description>High performance binary serialization for C#</Description>
    <Author>Philipp Naused</Author>
    <Company>$(Author)</Company>
    <RepositoryUrl>https://github.com/PhilippNaused/Bshox</RepositoryUrl>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <PackageProjectUrl>$(RepositoryUrl)</PackageProjectUrl>
    <Copyright>© $(Company)</Copyright>
    <RepositoryType>git</RepositoryType>
    <PackageRequireLicenseAcceptance>true</PackageRequireLicenseAcceptance>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>serializer</PackageTags>
  </PropertyGroup>

</Project>